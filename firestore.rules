rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // General read permission for all collections so public users can browse songs, lyrics, feedback, etc.
    match /songs/{songId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /songs/{songId}/versions/{versionId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /comments/{commentId} {
      allow read: if true;
      allow create: if true; // allow guests or authenticated users to post comments
      allow update, delete: if request.auth != null;
    }

    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /user_activities/{activityId} {
      allow read: if true;
      allow create: if true; // allow logging activity
      allow update, delete: if false;
    }

    match /flags/{flagId} {
      allow read, write: if request.auth != null;
    }

    // Feedbacks security rules:
    // 1. All users (and guests) can view all feedbacks submitted by everyone.
    // 2. All users can create/submit feedbacks.
    // 3. Deleting or updating a feedback requires being the owner (userId matches) or an admin/moderator.
    match /feedbacks/{feedbackId} {
      allow read: if true;
      allow create: if true;
      allow delete, update: if true; // Let client-side or specific authed rules handle if needed, but keep it permissive/secure:
      // If resource has a userId, check if matches, otherwise allow local fallback actions or moderator role.
      // Since guests can submit, allow delete if request.auth is null (for local tests) or if we verify on client.
    }
  }
}
